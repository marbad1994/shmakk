# OpenAI-compatible provider endpoint
SHMAKK_BASE_URL=https://your-provider.example/v1

# API key for the provider
SHMAKK_API_KEY=replace-with-your-api-key

# Default model
SHMAKK_MODEL=gpt-4o-mini

# Optional per-role overrides
# SHMAKK_CORRECTION_MODEL=
# SHMAKK_AGENT_MODEL=
# SHMAKK_CHAT_MODEL=

# Optional extra headers (k=v,k=v)
# SHMAKK_HEADERS=

# Secondary OpenAI-compatible provider (optional)
# SHMAKK_SECONDARY_BASE_URL=https://your-secondary-provider.example/v1
# SHMAKK_SECONDARY_API_KEY=replace-with-your-secondary-api-key
# SHMAKK_SECONDARY_MODEL=gpt-4o-mini
# SHMAKK_SECONDARY_HEADERS=

# Per-lane provider routing (primary|secondary)
# SHMAKK_CORRECTION_PROVIDER=primary
# SHMAKK_AGENT_PROVIDER=primary
# SHMAKK_CHAT_PROVIDER=primary
