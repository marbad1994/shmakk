# OpenAI-compatible provider endpoint
AITERM_BASE_URL=https://your-provider.example/v1

# API key for the provider
AITERM_API_KEY=replace-with-your-api-key

# Default model
AITERM_MODEL=gpt-4o-mini

# Optional per-role overrides
# AITERM_CORRECTION_MODEL=
# AITERM_AGENT_MODEL=
# AITERM_CHAT_MODEL=

# Optional extra headers (k=v,k=v)
# AITERM_HEADERS=

# Secondary OpenAI-compatible provider (optional)
# AITERM_SECONDARY_BASE_URL=https://your-secondary-provider.example/v1
# AITERM_SECONDARY_API_KEY=replace-with-your-secondary-api-key
# AITERM_SECONDARY_MODEL=gpt-4o-mini
# AITERM_SECONDARY_HEADERS=

# Per-lane provider routing (primary|secondary)
# AITERM_CORRECTION_PROVIDER=primary
# AITERM_AGENT_PROVIDER=primary
# AITERM_CHAT_PROVIDER=primary
